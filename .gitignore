# ===========================================================================
# .gitignore - DOCX OCR to Google Sheets
# ===========================================================================

# ── 敏感資訊（絕對不要提交！）──────────────────────────────────────────────
credentials.json
*-credentials.json
service-account*.json
service_account.json
.env
.env.local
secrets/

# ── 專案資料夾（內容是個別使用者的資料，不適合上版控）─────────────────────
docs/
work/
output/
*.docx
*.pdf
!sample/*.docx              # 若有放範例,可保留 sample 資料夾下的檔案

# ── Python 快取與虛擬環境 ─────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# 虛擬環境
.venv/
venv/
env/
ENV/
.virtualenv/

# 套件管理
*.egg-info/
*.egg
dist/
build/
pip-log.txt
pip-delete-this-directory.txt

# ── 測試與覆蓋率 ──────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover

# ── IDE / 編輯器 ──────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject

# Jupyter
.ipynb_checkpoints/
*.ipynb

# ── 作業系統 ──────────────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# ── 日誌與暫存 ────────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
*.backup
logs/

# ── 掃描輸出（生成資料，不進版控）────────────────────────────────────────
scan_results/
benchmark_results/

# ── OCR 中間產物 ──────────────────────────────────────────────────────────
*.zip
comparison.png              # 前處理對比圖（除錯用）
*_raw.pdf                   # 中間 PDF
*_ocr.pdf                   # OCR 後 PDF
results_backup.csv

# ── 其他 ──────────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
